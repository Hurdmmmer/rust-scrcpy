/// 鎶曢€掑壀璐存澘璁剧疆鍛戒护鍒颁細璇?worker銆?///
/// `paste=true` 鏃讹紝璁惧绔細灏濊瘯绔嬪埢鎵ц涓€娆＄矘璐村姩浣溿€?pub async fn set_clipboard(session_id: String, text: String, paste: bool) -> Result<()> {
    let sessions = lock_sessions()?;
    let Some(session) = sessions.get(&session_id) else {
        return Err(invalid_session_error(&session_id));
    };
    if let Some(worker) = &session.worker {
        worker
            .tx
            .try_send(RuntimeCommand::Clipboard { text, paste })
             .map_err(|e| ScrcpyError::Other(format!("send clipboard command failed: {}", e)))
    } else {
        Err(ScrcpyError::Other("session runtime not started".to_string()))
    }
}

/// 鎶曢€掓柟鍚戞ā寮忓懡浠ゅ埌浼氳瘽 worker銆?///
/// 褰撳墠瀹炵幇浼氳浆涓轰簨浠堕€氱煡锛屾柟渚夸笂灞傜粺涓€娑堣垂鏂瑰悜鐘舵€佸彉鍖栥€?pub async fn set_orientation_mode(session_id: String, mode: OrientationMode) -> Result<()> {
    let sessions = lock_sessions()?;
    let Some(session) = sessions.get(&session_id) else {
        return Err(invalid_session_error(&session_id));
    };
    if let Some(worker) = &session.worker {
        worker
            .tx
            .try_send(RuntimeCommand::SetOrientation(mode))
             .map_err(|e| ScrcpyError::Other(format!("send orientation command failed: {}", e)))
    } else {
        Err(ScrcpyError::Other("session runtime not started".to_string()))
    }
}

/// 鎶曢€?IDR 璇锋眰鍛戒护鍒颁細璇?worker銆?///
/// 鐢ㄤ簬鍦ㄨВ鐮佸紓甯稿悗璇锋眰鍏抽敭甯э紝鍔犲揩鐢婚潰鎭㈠銆?pub async fn request_idr(session_id: String) -> Result<()> {
    let sessions = lock_sessions()?;
