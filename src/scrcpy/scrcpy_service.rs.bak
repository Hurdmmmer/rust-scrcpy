#[cfg(windows)]
const CREATE_NO_WINDOW: u32 = 0x08000000;

/// 浼氳瘽 ID 閫掑璁℃暟鍣ㄣ€?///
/// 璁捐鐩殑锛?/// - 瀵瑰鏆撮湶鐨勪細璇?ID 鍙姹傚湪杩涚▼鍐呭敮涓€锛屼笉瑕佹眰璺ㄨ繘绋嬬ǔ瀹氾紱
/// - 浣跨敤鍘熷瓙閫掑鍙互閬垮厤鍏ㄥ眬閿佺珵浜夛紝骞朵笖瀹炵幇绠€鍗曞彲棰勬祴銆?static NEXT_SESSION_ID: AtomicU64 = AtomicU64::new(1);

/// 鍏ㄥ眬浼氳瘽琛ㄣ€?///
/// 琛ㄤ腑淇濆瓨 API 灞備細璇濈姸鎬侊紝閿负 `session_id`銆?/// 杩欓噷涓嶅仛鎸佷箙鍖栵紝杩涚▼閫€鍑哄悗浼氳瘽鑷劧澶辨晥銆?static API_SESSIONS: Lazy<Mutex<HashMap<String, ApiSession>>> =
    Lazy::new(|| Mutex::new(HashMap::new()));

/// 鏃ュ織鍒濆鍖栨爣璁般€?///
/// tracing subscriber 鍦ㄥ悓涓€杩涚▼閲屽彧鑳藉垵濮嬪寲涓€娆★紝
/// 杩欓噷鐢ㄥ竷灏斾綅淇濊瘉 `setup_logger` 骞傜瓑銆?static LOGGER_READY: Lazy<Mutex<bool>> = Lazy::new(|| Mutex::new(false));

/// 鍚庡彴 worker 鎺у埗鍛戒护銆?///
/// 鏋舵瀯璇存槑锛?/// - API 绾跨▼涓嶇洿鎺ヨЕ纰拌繍琛屾椂瀵硅薄锛?/// - 鎵€鏈夋帶鍒惰涓洪兘杞垚鍛戒护锛岄€氳繃閫氶亾鎶曢€掔粰浼氳瘽 worker锛?/// - 杩欐牱鍙互鎶婂苟鍙戣闂敹鏁涘埌鍗曠嚎绋嬶紝鍑忓皯閿佸拰鐘舵€佺珵浜夈€?enum RuntimeCommand {
    Stop,
    Touch(TouchEvent),
    Key(KeyEvent),
    Scroll(ScrollEvent),
    Text(String),
    Clipboard { text: String, paste: bool },
    SystemKey(SystemKey),
    SetOrientation(OrientationMode),
    RequestIdr,
}

/// 鍗曚細璇濆悗鍙?worker銆?///
/// 瀛楁璇箟锛?/// - `tx`锛欰PI -> worker 鍛戒护閫氶亾锛?/// - `running`锛氳法绾跨▼鍙鐨勮繍琛屾爣璁帮紝鐢ㄤ簬蹇€熼€€鍑猴紱
/// - `stats`锛氭渶杩戜竴娆＄粺璁″揩鐓э紝渚?API 绾跨▼璇诲彇锛?/// - `join`锛氱嚎绋嬪彞鏌勶紝鐢ㄤ簬 stop/dispose 闃舵闃诲鍥炴敹銆?struct RuntimeWorker {
    tx: Sender<RuntimeCommand>,
    running: Arc<AtomicBool>,
    stats: Arc<Mutex<SessionStats>>,
    join: Option<JoinHandle<()>>,
}

/// API 灞備細璇濈姸鎬併€?///
/// 璇ョ粨鏋勫彧淇濆瓨鈥滈厤缃笌杩愯鍙ユ焺鈥濓紝涓嶅瓨鏀鹃噸鍨?runtime 瀵硅薄锛?/// 閬垮厤鍦ㄥ叏灞€浼氳瘽琛ㄤ腑鎸佹湁涓嶅彲 Send 鐨勫鏉傜姸鎬併€?struct ApiSession {
    config: SessionConfig,
    decoder_mode: DecoderMode,
    render_pipeline_mode: RenderPipelineMode,
    worker: Option<RuntimeWorker>,
}

/// 鑾峰彇鍏ㄥ眬浼氳瘽琛ㄤ簰鏂ラ攣銆?///
/// 缁熶竴鍦ㄨ繖閲岃浆鎹?poison 閿欒锛岄伩鍏嶆瘡涓皟鐢ㄧ偣閲嶅閿欒鏄犲皠浠ｇ爜銆?fn lock_sessions() -> Result<MutexGuard<'static, HashMap<String, ApiSession>>> {
    API_SESSIONS
        .lock()
        .map_err(|_| ScrcpyError::Other("api session map poisoned".to_string()))
}

/// 鐢熸垚鏂颁細璇?ID銆?///
/// 杩斿洖鏍煎紡鍥哄畾涓?`sess-{number}`锛屼究浜庢棩蹇楁绱笌鎺掓煡銆?fn new_session_id() -> String {
    format!("sess-{}", NEXT_SESSION_ID.fetch_add(1, Ordering::Relaxed))
}

/// 缁熶竴鏋勯€犫€滀細璇濅笉瀛樺湪鈥濋敊璇€?///
/// 杩欐牱鍙互淇濊瘉涓嶅悓 API 鐨勯敊璇枃妗堜竴鑷达紝鍑忓皯鍓嶇鍒ゆ柇鍒嗘敮銆?fn invalid_session_error(session_id: &str) -> ScrcpyError {
    ScrcpyError::Other(format!("invalid session id: {}", session_id))
}

/// 灏嗕笟鍔℃棩蹇楃骇鍒槧灏勪负 tracing 绾у埆銆?///
/// 璇ユ槧灏勬槸 1:1 璇箟鏄犲皠锛屼笉鍋氶檷绾?鍗囩骇杞崲銆?fn map_level(level: LogLevel) -> Level {
    match level {
        LogLevel::Trace => Level::TRACE,
        LogLevel::Debug => Level::DEBUG,
        LogLevel::Info => Level::INFO,
        LogLevel::Warn => Level::WARN,
        LogLevel::Error => Level::ERROR,
    }
}

/// 鍒涘缓榛樿缁熻瀵硅薄銆?///
/// 鍦ㄤ細璇濆皻鏈惎鍔ㄦ垨缁熻灏氫笉鍙敤鏃惰繑鍥烇紝閬垮厤 API 渚у嚭鐜扮┖鍊煎垽鏂€?fn default_stats() -> SessionStats {
    SessionStats {
        fps: 0.0,
        decode_latency_ms: 0,
        upload_latency_ms: 0,
        total_frames: 0,
        dropped_frames: 0,
    }
}

/// 灏?Flutter API 浼氳瘽閰嶇疆鏄犲皠涓烘柊鏋舵瀯瀹㈡埛绔厤缃€?///
/// 绾︽潫锛?/// - 瀛楁璇箟灏介噺淇濇寔鐩撮€氾紝閬垮厤闅愬紡鎹㈢畻锛?/// - 浠呭湪瀛楁鍚嶄笉鍚屽満鏅笅鍋氭満姊版槧灏勶紝閬垮厤寮曞叆閰嶇疆婕傜Щ銆?fn map_client_config(config: &SessionConfig) -> ScrcpyClientConfig {
    ScrcpyClientConfig {
        adb_path: config.adb_path.clone(),
        server_path: config.server_path.clone(),
        device_id: config.device_id.clone(),
        video_port: config.video_port,
        control_port: config.control_port,
        max_size: config.max_size,
        bit_rate: config.bit_rate,
        max_fps: config.max_fps,
        intra_refresh_period: config.intra_refresh_period,
        video_encoder: config.video_encoder.clone(),
        turn_screen_off: config.turn_screen_off,
        stay_awake: config.stay_awake,
        scrcpy_log_level: config.scrcpy_verbosity.clone(),
        // 当前 API 尚未透传输入后端配置，先走自动模式（优先UHID，失败回退Inject）。
        input_mode: ScrcpyInputMode::Auto,
    }
}

/// 灏?API 灞傝В鐮?娓叉煋妯″紡鏄犲皠涓烘柊鏋舵瀯 decode pipeline 閰嶇疆銆?///
/// 褰撳墠绛栫暐锛?/// - `Original` 璧?GPU 鍏变韩鍙ユ焺閾捐矾锛?/// - `CpuPixelBufferV2` 璧?CPU BGRA 閾捐矾銆?fn map_decode_config(
    decoder_mode: DecoderMode,
    render_pipeline_mode: RenderPipelineMode,
) -> ScrcpyDecodeConfig {
    let mut cfg = ScrcpyDecodeConfig::default();
    cfg.decoder_mode = decoder_mode;
    cfg.output_mode = match render_pipeline_mode {
        RenderPipelineMode::Original => crate::scrcpy::decode_core::DecoderOutputMode::GpuShared,
        RenderPipelineMode::CpuPixelBufferV2 => crate::scrcpy::decode_core::DecoderOutputMode::CpuBgra,
    };
    cfg
}

/// 灏?Flutter API 渚цЕ鎽镐簨浠舵槧灏勪负鏂?runtime 鎺у埗浜嬩欢銆?///
/// 杩欓噷鎸夊崗璁?action 鏁板€煎仛鏄犲皠锛屼笉鐩存帴渚濊禆鍘嗗彶鐩綍鏋氫妇绫诲瀷銆?/// 褰?action 闈炴硶鏃讹紝榛樿闄嶇骇涓?`Move`锛岄伩鍏嶈緭鍏ュ紓甯稿鑷寸嚎绋嬪穿婧冦€?fn map_touch_event(event: TouchEvent) -> AndroidTouchEvent {
    let action = match event.action as u8 {
        0 => AndroidMotionEventAction::Down,
        1 => AndroidMotionEventAction::Up,
        2 => AndroidMotionEventAction::Move,
        3 => AndroidMotionEventAction::Cancel,
        5 => AndroidMotionEventAction::PointerDown,
        6 => AndroidMotionEventAction::PointerUp,
        7 => AndroidMotionEventAction::HoverMove,
        9 => AndroidMotionEventAction::HoverEnter,
        10 => AndroidMotionEventAction::HoverExit,
        _ => AndroidMotionEventAction::Move,
    };
    AndroidTouchEvent {
        action,
        pointer_id: event.pointer_id,
        x: event.x,
        y: event.y,
        pressure: event.pressure,
        width: event.width,
        height: event.height,
        buttons: event.buttons,
    }
}

/// 灏?Flutter API 渚ф寜閿簨浠舵槧灏勪负鏂?runtime 鎺у埗浜嬩欢銆?///
/// 褰?action 闈炴硶鏃讹紝榛樿闄嶇骇涓?`Down`锛屼繚璇佹帶鍒堕€氶亾娑堟伅浠嶅彲鍙戦€併€?fn map_key_event(event: KeyEvent) -> AndroidKeyEvent {
    let action = match event.action as u8 {
        0 => AndroidKeyEventAction::Down,
        1 => AndroidKeyEventAction::Up,
        _ => AndroidKeyEventAction::Down,
    };
    AndroidKeyEvent {
        action,
        keycode: event.keycode,
        repeat: event.repeat,
        metastate: event.metastate,
    }
}

/// 灏?Flutter API 渚ф粴杞簨浠舵槧灏勪负鏂?runtime 鎺у埗浜嬩欢銆?///
/// 璇ュ嚱鏁颁笉鍋氬潗鏍囩郴鎹㈢畻锛屽彧鍋氱粨鏋勬惉杩愶紝鎹㈢畻鐢辨帶鍒跺眰澶勭悊銆?fn map_scroll_event(event: ScrollEvent) -> AndroidScrollEvent {
    AndroidScrollEvent {
        x: event.x,
        y: event.y,
        width: event.width,
        height: event.height,
        hscroll: event.hscroll,
        vscroll: event.vscroll,
    }
}

/// 灏嗚涔夌郴缁熼敭鏄犲皠涓?Android keycode銆?///
/// `RotateScreen` 鏆傛棤鐩存帴 keycode 瀵瑰簲锛岃繑鍥?`None`銆?fn system_key_to_keycode(key: SystemKey) -> Option<u32> {
    match key {
        SystemKey::Home => Some(3),
        SystemKey::Back => Some(4),
        SystemKey::Recent => Some(187),
        SystemKey::PowerMenu => Some(26),
        SystemKey::VolumeUp => Some(24),
        SystemKey::VolumeDown => Some(25),
        SystemKey::RotateScreen => None,
    }
}

/// 鎶婁細璇濅簨浠跺簭鍒楀寲涓?JSON锛屽苟鎶曢€掑埌 Flutter 鍥炶皟娉ㄥ唽鍣ㄣ€?///
/// 澶辫触绛栫暐锛?/// - 搴忓垪鍖栧け璐ユ椂闈欓粯蹇界暐锛堜笉 panic銆佷笉闃绘柇涓绘祦绋嬶級锛?/// - 鍘熷洜鏄簨浠堕€氱煡灞炰簬鏃佽矾鑳藉姏锛屼笉搴旀嫋鍨富浼氳瘽閾捐矾銆?fn notify_session_event_json(session_id: &str, event: &SessionEvent) {
    if let Ok(payload) = serde_json::to_vec(event) {
        flutter_callback_register::notify_session_event(session_id, &payload);
    }
}

/// 鐩存帴鎵ц adb 鍛戒护骞惰繑鍥?stdout 鏂囨湰銆?///
/// 琛屼负绾︽潫锛?/// - stdout/stderr 閮芥崟鑾凤紝渚夸簬澶辫触璇婃柇锛?/// - 闈為浂閫€鍑虹爜缁熶竴鏄犲皠涓?`ScrcpyError::Other`锛?/// - Windows 涓嬪叧闂脊绐楋紝閬垮厤褰卞搷妗岄潰搴旂敤浣撻獙銆?async fn adb_execute(adb_path: &str, args: &[&str]) -> Result<String> {
    let mut cmd = Command::new(adb_path);
    cmd.args(args).stdout(Stdio::piped()).stderr(Stdio::piped());
    #[cfg(windows)]
    cmd.creation_flags(CREATE_NO_WINDOW);

    let output = cmd
        .output()
        .await
        .map_err(|e| ScrcpyError::Other(format!("adb execute failed: {}", e)))?;

    if !output.status.success() {
        return Err(ScrcpyError::Other(format!(
            "adb command failed: {}",
            String::from_utf8_lossy(&output.stderr)
        )));
    }

    Ok(String::from_utf8_lossy(&output.stdout).to_string())
}

/// 鎵ц璁惧鏂瑰悜妯″紡鍒囨崲銆?///
/// 璇ヨ兘鍔涘繀椤昏蛋 adb 绯荤粺璁剧疆锛岃€屼笉鏄粎鍙戦€佷簨浠讹紝
/// 鍚﹀垯浼氬嚭鐜扳€滀笂灞傜湅鍒版柟鍚戝彉鍖栦簨浠讹紝浣嗚澶囨柟鍚戞病鏈夊彉鍖栤€濈殑鍋囩姸鎬併€?async fn adb_set_orientation_mode(
    adb_path: &str,
    device_id: &str,
    mode: OrientationMode,
) -> Result<()> {
    // Android 11+/12+/13 涓婏紝`cmd window user-rotation` 閫氬父姣旂洿鎺ュ啓 settings 鏇村彲闈犮€?    // 杩欓噷閲囩敤鈥滄柊鍛戒护浼樺厛锛屾棫鍛戒护鍏滃簳鈥濈殑绛栫暐锛岄伩鍏嶉儴鍒?ROM 涓婃柟鍚戣缃棤鏁堛€?    async fn adb_shell_try(adb_path: &str, device_id: &str, command: &str) -> Result<()> {
        let _ = adb_execute(adb_path, &["-s", device_id, "shell", command]).await?;
        Ok(())
    }

    match mode {
        OrientationMode::Auto => {
            if adb_shell_try(adb_path, device_id, "cmd window user-rotation free")
                .await
                .is_err()
            {
                let _ = adb_execute(
                    adb_path,
                    &["-s", device_id, "shell", "settings put system accelerometer_rotation 1"],
                )
                .await?;
            }
        }
        OrientationMode::Portrait => {
            if adb_shell_try(adb_path, device_id, "cmd window user-rotation lock 0")
                .await
                .is_err()
            {
                let _ = adb_execute(
                    adb_path,
                    &["-s", device_id, "shell", "settings put system accelerometer_rotation 0"],
                )
                .await?;
                let _ = adb_execute(
                    adb_path,
                    &["-s", device_id, "shell", "settings put system user_rotation 0"],
                )
                .await?;
            }
        }
        OrientationMode::Landscape => {
            if adb_shell_try(adb_path, device_id, "cmd window user-rotation lock 1")
                .await
                .is_err()
            {
                let _ = adb_execute(
                    adb_path,
                    &["-s", device_id, "shell", "settings put system accelerometer_rotation 0"],
                )
                .await?;
                let _ = adb_execute(
                    adb_path,
                    &["-s", device_id, "shell", "settings put system user_rotation 1"],
                )
                .await?;
            }
        }
    }

    Ok(())
}
/// 澶勭悊涓€鏉¤繍琛屾椂鍛戒护銆?///
/// 杩斿洖鍊艰涔夛細
/// - `true`锛氱户缁繍琛岋紱
/// - `false`锛氭敹鍒板仠姝俊鍙凤紝閫€鍑轰富寰幆銆?async fn handle_runtime_command(
    runtime: &mut ScrcpyCoreRuntime,
    session_id: &str,
    config: &SessionConfig,
    cmd: RuntimeCommand,
) -> bool {
    match cmd {
        RuntimeCommand::Stop => false,
        RuntimeCommand::Touch(e) => {
            let _ = runtime.send_touch(session_id, &map_touch_event(e)).await;
            true
        }
        RuntimeCommand::Key(e) => {
            let _ = runtime.send_key(session_id, &map_key_event(e)).await;
            true
        }
        RuntimeCommand::Scroll(e) => {
            let _ = runtime.send_scroll(session_id, &map_scroll_event(e)).await;
            true
        }
        RuntimeCommand::Text(text) => {
            let _ = runtime.send_text(session_id, &text).await;
            true
        }
        RuntimeCommand::Clipboard { text, paste } => {
            let _ = runtime.set_clipboard(session_id, &text, paste).await;
            true
        }
        RuntimeCommand::SystemKey(key) => {
            if let Some(keycode) = system_key_to_keycode(key) {
                let down = AndroidKeyEvent {
                    action: AndroidKeyEventAction::Down,
                    keycode,
                    repeat: 0,
                    metastate: 0,
                };
                let up = AndroidKeyEvent {
                    action: AndroidKeyEventAction::Up,
                    keycode,
                    repeat: 0,
                    metastate: 0,
                };
                let _ = runtime.send_key(session_id, &down).await;
                let _ = runtime.send_key(session_id, &up).await;
            }
            true
        }
        RuntimeCommand::SetOrientation(mode) => {
            let result = match mode {
                OrientationMode::Portrait => {
                    // 鍗忚璺緞锛氭寜鈥滃綋鍓嶅垎杈ㄧ巼鈥濆垽瀹氭槸鍚﹂渶瑕佸彂閫佷竴娆?RotateDevice銆?                    runtime.set_orientation_mode(session_id, true).await
                }
                OrientationMode::Landscape => {
                    // 鍗忚璺緞锛氭寜鈥滃綋鍓嶅垎杈ㄧ巼鈥濆垽瀹氭槸鍚﹂渶瑕佸彂閫佷竴娆?RotateDevice銆?                    runtime.set_orientation_mode(session_id, false).await
                }
                OrientationMode::Auto => {
                    // 鍗忚娌℃湁鈥滄仮澶嶈嚜鍔ㄦ棆杞€濆懡浠わ紝Auto 浠嶉€氳繃 adb 璁剧疆銆?                    adb_set_orientation_mode(&config.adb_path, &config.device_id, mode).await
                }
            };

            match result {
                Ok(_) => {
                    notify_session_event_json(
                        session_id,
                        &SessionEvent::OrientationChanged {
                            mode,
                            source: OrientationChangeSource::ManualApi,
                        },
                    );
                }
                Err(e) => {
                    warn!(
                        "[鏂版湇鍔 璁剧疆鏂瑰悜澶辫触: session_id={}, mode={:?}, err={}",
                        session_id,
                        mode,
                        e
                    );
                    notify_session_event_json(
                        session_id,
                        &SessionEvent::Error {
                            code: crate::gh_common::model::ErrorCode::ControlFailed,
                            message: format!("set orientation failed: {}", e),
                        },
                    );
                }
            }
            true
        }
        RuntimeCommand::RequestIdr => {
            let _ = runtime.request_idr(session_id).await;
            true
        }
    }
}
/// 鍚姩鍗曚細璇濆悗鍙扮嚎绋嬨€?///
/// 绾跨▼鑱岃矗锛?/// - 鍚姩骞舵寔鏈?runtime锛?/// - 娑堣垂鎺у埗鍛戒护锛?/// - 鎸佺画瑙ｇ爜娉甸€侊紱
/// - 妫€娴嬮噸杩炰俊鍙峰苟鎵ц鑷姩閲嶈繛闂幆銆?fn spawn_runtime_worker(
    session_id: String,
    config: SessionConfig,
    decoder_mode: DecoderMode,
    render_pipeline_mode: RenderPipelineMode,
) -> RuntimeWorker {
    // 浣跨敤鏈夌晫寮傛閫氶亾锛屾瀯寤?Selector 椋庢牸浜嬩欢寰幆銆?
    // 鐩殑锛氬懡浠や笌瑙嗛瑙ｇ爜绔炰簤鎵ц鏉冿紝Stop 鍛戒护鍙揩閫熸姠鍗犮€?
    let (tx, mut rx): (Sender<RuntimeCommand>, Receiver<RuntimeCommand>) = mpsc::channel(256);
    let running = Arc::new(AtomicBool::new(true));
    let stats = Arc::new(Mutex::new(default_stats()));

    let running_c = Arc::clone(&running);
    let stats_c = Arc::clone(&stats);
    let session_id_c = session_id.clone();

    // 姣忎釜浼氳瘽鐙崰涓€涓?worker 绾跨▼锛岄伩鍏嶈法浼氳瘽鐘舵€佷覆鎵般€?    let join = std::thread::spawn(move || {
        let rt = match tokio::runtime::Builder::new_current_thread().enable_all().build() {
            Ok(v) => v,
            Err(e) => {
                warn!("[鏂版湇鍔 鍒涘缓 tokio runtime 澶辫触: {}", e);
                notify_session_event_json(
                    &session_id_c,
                    &SessionEvent::Error {
                        code: crate::gh_common::model::ErrorCode::Internal,
                        message: format!("runtime init failed: {}", e),
                    },
                );
                running_c.store(false, Ordering::Relaxed);
                return;
            }
        };

        rt.block_on(async move {
            let client = ScrcpyClient::new(map_client_config(&config));
            let mut runtime = ScrcpyCoreRuntime::new(client);
            runtime.set_decode_config(map_decode_config(decoder_mode, render_pipeline_mode));

            // 浼氳瘽鍚姩鍓嶆墽琛岃澶囬槻浼戠湢绛栫暐銆?            if config.stay_awake {
                if let Err(e) = adb_execute(
                    &config.adb_path,
                    &["-s", &config.device_id, "shell", "svc power stayon true"],
                )
                .await
                {
                    warn!(
                        "[鏂版湇鍔 璁剧疆璁惧闃蹭紤鐪犲け璐ワ紙缁х画鍚姩锛? session_id={}, err={}",
                        session_id_c, e
                    );
                }
            }

            if let Err(e) = runtime.start(session_id_c.clone()).await {
                warn!("[鏂版湇鍔 鍚姩浼氳瘽澶辫触: session_id={}, err={}", session_id_c, e);
                running_c.store(false, Ordering::Relaxed);
                return;
            }

            // 浼氳瘽鍚姩鍚庢寜閰嶇疆鎵ц涓€娆＄唲灞忕瓥鐣ャ€?            if config.turn_screen_off {
                if let Err(e) = runtime.set_display_power(&session_id_c, false).await {
                    warn!(
                        "[鏂版湇鍔 浼氳瘽鍚姩鍚庣唲灞忓け璐ワ紙涓嶄腑鏂細璇濓級: session_id={}, err={}",
                        session_id_c, e
                    );
                }
            }

            // Selector 椋庢牸涓诲惊鐜細
            // - `rx.recv()` 浠ｈ〃鎺у埗闈簨浠讹紱
            // - `decode_pump` 浠ｈ〃鏁版嵁闈簨浠讹紱
            // - Stop 鍛戒护鍙姠鍗犺В鐮佽矾寰勶紝蹇€熻繘鍏ヨ祫婧愬洖鏀躲€?            while running_c.load(Ordering::Relaxed) {
                tokio::select! {
                    cmd = rx.recv() => {
                        match cmd {
                            Some(cmd) => {
                                let keep_running = handle_runtime_command(
                                    &mut runtime,
                                    &session_id_c,
                                    &config,
                                    cmd,
                                ).await;
                                if !keep_running {
                                    running_c.store(false, Ordering::Relaxed);
                                }
                            }
                            None => {
                                // 鍛戒护鍙戦€佺宸插叧闂紝缁撴潫 worker銆?                                running_c.store(false, Ordering::Relaxed);
                            }
                        }
                    }
                    pump_result = runtime.decode_pump(&session_id_c, 8) => {
                        if let Err(e) = pump_result {
                            warn!(
                                "[鏂版湇鍔 瑙ｇ爜娉甸€佸け璐ワ紝缁撴潫浼氳瘽: session_id={}, err={}",
                                session_id_c, e
                            );
                            running_c.store(false, Ordering::Relaxed);
                        }
                    }
                }

                if !running_c.load(Ordering::Relaxed) {
                    break;
                }

                // 鑷姩閲嶈繛闂幆锛歴top -> 鐭瓑寰?-> start銆?                if let Ok(true) = runtime.decode_reconnect_required(&session_id_c) {
                    warn!("[鏂版湇鍔 妫€娴嬪埌閲嶈繛淇″彿锛屾墽琛岃嚜鍔ㄩ噸杩? session_id={}", session_id_c);
                    let _ = runtime.stop(&session_id_c).await;
                    tokio::time::sleep(Duration::from_millis(120)).await;
                    if let Err(e) = runtime.start(session_id_c.clone()).await {
                        warn!(
                            "[鏂版湇鍔 鑷姩閲嶈繛澶辫触锛岀粨鏉熶細璇? session_id={}, err={}",
                            session_id_c, e
                        );
                        running_c.store(false, Ordering::Relaxed);
                        break;
                    }
                }

                // 缁熻蹇収鎸夊惊鐜鐩栧啓鍏ワ紝API 璇诲彇鍒扮殑鏄渶杩戜竴娆″彲鐢ㄥ€笺€?                if let Ok(s) = runtime.session_stats(&session_id_c) {
                    if let Ok(mut g) = stats_c.lock() {
                        *g = s;
                    }
                }
            }

            // 閫€鍑哄墠鍏滃簳鍋滄 runtime锛岀‘淇濊繛鎺ヤ笌璧勬簮琚噴鏀俱€?            let _ = runtime.stop(&session_id_c).await;
            running_c.store(false, Ordering::Relaxed);
        });
    });

    RuntimeWorker {
        tx,
        running,
        stats,
        join: Some(join),
    }
}

/// 鍒濆鍖?Rust 渚ф棩蹇楃郴缁熴€?///
/// 骞傜瓑璇箟锛?/// - 鍚屼竴杩涚▼鍙厑璁稿垵濮嬪寲涓€娆★紱
/// - 鍚庣画閲嶅璋冪敤鐩存帴杩斿洖鎴愬姛锛屼笉浼氶噸澶嶅畨瑁?subscriber銆?pub async fn setup_logger(max_level: LogLevel) -> Result<()> {
    let mut guard = LOGGER_READY
        .lock()
        .map_err(|_| ScrcpyError::Other("logger state lock poisoned".to_string()))?;
    if *guard {
        return Ok(());
    }

    let level = map_level(max_level);
    tracing_subscriber::fmt()
        .with_max_level(level)
        .with_target(true)
        .with_thread_ids(true)
        .with_file(true)
        .with_line_number(true)
        .with_ansi(false)
        .finish()
        .try_init()
        .map_err(|e| ScrcpyError::Other(format!("setup logger failed: {}", e)))?;

    *guard = true;
    info!("rust-scrcpy 鏂版湇鍔℃棩蹇楀垵濮嬪寲瀹屾垚, level={:?}", level);
    Ok(())
}

/// 閫氳繃 adb 鍒楀嚭鍦ㄧ嚎璁惧銆?///
/// 杩斿洖绛栫暐锛?/// - 鍙繚鐣?`state == device` 鐨勬潯鐩紱
/// - 鍨嬪彿銆佺増鏈€佸垎杈ㄧ巼鍦ㄥ垪琛ㄩ樁娈典笉棰濆鏌ヨ锛岄伩鍏嶆參鏌ヨ闃诲鎺ュ彛銆?pub async fn list_devices(adb_path: String) -> Result<Vec<DeviceInfo>> {
    let out = adb_execute(&adb_path, &["devices"]).await?;
    let mut devices = Vec::new();
    for line in out.lines() {
        let line = line.trim();
        if line.is_empty() || line.starts_with("List of devices") {
            continue;
        }
        if let Some((id, state)) = line.split_once('\t') {
            if state.trim() == "device" {
                devices.push(DeviceInfo {
                    device_id: id.trim().to_string(),
                    model: "Unknown".to_string(),
                    android_version: "Unknown".to_string(),
                    width: 0,
                    height: 0,
                    ip: None,
                });
            }
        }
    }
    Ok(devices)
}

/// 鏌ヨ鍗曡澶囪缁嗕俊鎭€?///
/// 鏌ヨ鏉ユ簮锛?/// - 鍨嬪彿锛歚ro.product.model`
/// - 绯荤粺鐗堟湰锛歚ro.build.version.release`
/// - 鍒嗚鲸鐜囷細`wm size`
///
/// 浠讳竴瀛楁鏌ヨ澶辫触鏃堕檷绾т负榛樿鍊硷紝鑰屼笉鏄暣鎺ュ彛澶辫触銆?pub async fn get_device_info(adb_path: String, device_id: String) -> Result<DeviceInfo> {
    let model = adb_execute(&adb_path, &["-s", &device_id, "shell", "getprop ro.product.model"])
        .await
        .unwrap_or_else(|_| "Unknown".to_string())
        .trim()
        .to_string();

    let android_version = adb_execute(
        &adb_path,
        &["-s", &device_id, "shell", "getprop ro.build.version.release"],
    )
    .await
    .unwrap_or_else(|_| "Unknown".to_string())
    .trim()
    .to_string();

    let size_raw = adb_execute(&adb_path, &["-s", &device_id, "shell", "wm size"])
        .await
        .unwrap_or_else(|_| String::new());
    let (width, height) = parse_wm_size(&size_raw).unwrap_or((0, 0));

    Ok(DeviceInfo {
        device_id,
        model,
        android_version,
        width,
        height,
        ip: None,
    })
}

/// 浠?`wm size` 鍛戒护杈撳嚭涓彁鍙栧楂樸€?///
/// 鍏煎鏍煎紡锛?/// - `Physical size: 1080x2400`
/// - `1080x2400`
fn parse_wm_size(raw: &str) -> Option<(u32, u32)> {
    for line in raw.lines() {
        let line = line.trim();
        if let Some(idx) = line.find(':') {
            let size = line[idx + 1..].trim();
            if let Some((w, h)) = parse_size_pair(size) {
                return Some((w, h));
            }
        } else if let Some((w, h)) = parse_size_pair(line) {
            return Some((w, h));
        }
    }
    None
}

/// 瑙ｆ瀽 `WxH` 鏂囨湰涓哄楂樻暣鏁般€?///
/// 杩斿洖 `None` 鐨勫満鏅細
/// - 涓嶆槸鍚堟硶鏁板瓧锛?/// - 瀹芥垨楂樹负 0銆?fn parse_size_pair(value: &str) -> Option<(u32, u32)> {
    let mut parts = value.split('x');
    let w = parts.next()?.trim().parse::<u32>().ok()?;
    let h = parts.next()?.trim().parse::<u32>().ok()?;
    if w == 0 || h == 0 {
        return None;
    }
    Some((w, h))
}

/// 鍒涘缓浼氳瘽锛圴1锛夈€?///
/// 琛屼负璇存槑锛?/// - 鍙敞鍐岄厤缃苟杩斿洖 `session_id`锛?/// - 涓嶄細鍚姩杩炴帴涓庤В鐮佺嚎绋嬶紱
/// - 榛樿浣跨敤纭В浼樺厛 + 鍘熷娓叉煋閾捐矾銆?pub async fn create_session(config: SessionConfig) -> Result<String> {
    let session_id = new_session_id();
    let session = ApiSession {
        config,
        decoder_mode: DecoderMode::PreferHardware,
        render_pipeline_mode: RenderPipelineMode::Original,
        worker: None,
    };
    lock_sessions()?.insert(session_id.clone(), session);
    Ok(session_id)
}

/// 鍒涘缓浼氳瘽锛圴2锛夈€?///
/// 涓?V1 鐨勫樊寮傦細
/// - 鏄惧紡鎺ユ敹瑙ｇ爜妯″紡涓庢覆鏌撴ā寮忥紱
/// - 鍏跺畠琛屼负涓?V1 涓€鑷达紙浠呮敞鍐岋紝涓嶅惎鍔級銆?pub async fn create_session_v2(config: SessionConfigV2) -> Result<String> {
    let session_id = new_session_id();
    let session = ApiSession {
        config: config.base,
        decoder_mode: config.decoder_mode,
        render_pipeline_mode: config.render_pipeline_mode,
        worker: None,
    };
    lock_sessions()?.insert(session_id.clone(), session);
    Ok(session_id)
}

/// 鍚姩浼氳瘽銆?///
/// 骞傜瓑璇箟锛?/// - 鑻ヤ細璇濆凡鍦ㄨ繍琛岋紝鍒欑洿鎺ヨ繑鍥炴垚鍔燂紱
/// - 鑻ヤ細璇濆瓨鍦ㄤ絾鏈繍琛岋紝鍒欐媺璧?worker銆?pub async fn start_session(session_id: String) -> Result<()> {
    let mut sessions = lock_sessions()?;
    let Some(session) = sessions.get_mut(&session_id) else {
        return Err(invalid_session_error(&session_id));
    };

    if let Some(worker) = &session.worker {
        if worker.running.load(Ordering::Relaxed) {
            return Ok(());
        }
    }

    let worker = spawn_runtime_worker(
        session_id.clone(),
        session.config.clone(),
        session.decoder_mode,
        session.render_pipeline_mode,
    );
    session.worker = Some(worker);
    Ok(())
}

/// 鍋滄浼氳瘽銆?///
/// 琛屼负璇存槑锛?/// - 鍚?worker 鍙戦€?`Stop` 鍛戒护锛?/// - 绛夊緟绾跨▼鍥炴敹锛?/// - 淇濈暀浼氳瘽閰嶇疆锛屽彲鍐嶆 `start_session`銆?pub async fn stop_session(session_id: String) -> Result<()> {
    let mut sessions = lock_sessions()?;
    let Some(session) = sessions.get_mut(&session_id) else {
        return Err(invalid_session_error(&session_id));
    };

    if let Some(worker) = &mut session.worker {
        let _ = worker.tx.try_send(RuntimeCommand::Stop);
        worker.running.store(false, Ordering::Relaxed);
        if let Some(join) = worker.join.take() {
            let _ = join.join();
        }
    }
    session.worker = None;
    Ok(())
}

/// 閿€姣佷細璇濄€?///
/// 涓?`stop_session` 鐨勫尯鍒細
/// - `dispose` 浼氫粠鍏ㄥ眬浼氳瘽琛ㄧЩ闄よ浼氳瘽锛?/// - 绉婚櫎鍚庤 `session_id` 涓嶅彲鍐嶆浣跨敤銆?pub async fn dispose_session(session_id: String) -> Result<()> {
    let mut sessions = lock_sessions()?;
    let Some(mut session) = sessions.remove(&session_id) else {
        return Err(invalid_session_error(&session_id));
    };

    if let Some(worker) = &mut session.worker {
        let _ = worker.tx.try_send(RuntimeCommand::Stop);
        worker.running.store(false, Ordering::Relaxed);
        if let Some(join) = worker.join.take() {
            let _ = join.join();
        }
    }
    Ok(())
}

/// 鎶曢€掕Е鎽稿懡浠ゅ埌浼氳瘽 worker銆?///
/// 璇ユ帴鍙ｅ彧璐熻矗鍛戒护鎶曢€掞紝涓嶄繚璇佽澶囩宸茬粡澶勭悊瀹屾垚銆?pub async fn send_touch(session_id: String, event: TouchEvent) -> Result<()> {
    let sessions = lock_sessions()?;
    let Some(session) = sessions.get(&session_id) else {
        return Err(invalid_session_error(&session_id));
    };
    if let Some(worker) = &session.worker {
        worker
            .tx
            .try_send(RuntimeCommand::Touch(event))
             .map_err(|e| ScrcpyError::Other(format!("send touch command failed: {}", e)))
    } else {
        Err(ScrcpyError::Other("session runtime not started".to_string()))
    }
}

